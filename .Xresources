! X colors.
! Generated by 'wal'
*foreground:        #e3c8a8
*background:        #0a0800
*.foreground:       #e3c8a8
*.background:       #0a0800
emacs*foreground:   #e3c8a8
emacs*background:   #0a0800
URxvt*foreground:   #e3c8a8
XTerm*foreground:   #e3c8a8
UXTerm*foreground:  #e3c8a8
URxvt*background:   [100]#0a0800
XTerm*background:   #0a0800
UXTerm*background:  #0a0800
URxvt*cursorColor:  #e3c8a8
XTerm*cursorColor:  #e3c8a8
UXTerm*cursorColor: #e3c8a8
URxvt*borderColor:  [100]#0a0800

! Colors 0-15.
*.color0: #0a0800
*color0:  #0a0800
*.color1: #746B4B
*color1:  #746B4B
*.color2: #93602E
*color2:  #93602E
*.color3: #B56031
*color3:  #B56031
*.color4: #917850
*color4:  #917850
*.color5: #7E8166
*color5:  #7E8166
*.color6: #9E8C66
*color6:  #9E8C66
*.color7: #e3c8a8
*color7:  #e3c8a8
*.color8: #9e8c75
*color8:  #9e8c75
*.color9: #746B4B
*color9:  #746B4B
*.color10: #93602E
*color10:  #93602E
*.color11: #B56031
*color11:  #B56031
*.color12: #917850
*color12:  #917850
*.color13: #7E8166
*color13:  #7E8166
*.color14: #9E8C66
*color14:  #9E8C66
*.color15: #e3c8a8
*color15:  #e3c8a8

! Black color that will not be affected by bold highlighting.
*.color66: #0a0800
*color66:  #0a0800

! Xclock colors.
XClock*foreground: #e3c8a8
XClock*background: #0a0800
XClock*majorColor:  rgba:e3/c8/a8/ff
XClock*minorColor:  rgba:e3/c8/a8/ff
XClock*hourColor:   rgba:e3/c8/a8/ff
XClock*minuteColor: rgba:e3/c8/a8/ff
XClock*secondColor: rgba:e3/c8/a8/ff

! Set depth to make transparency work.
URxvt*depth: 32
